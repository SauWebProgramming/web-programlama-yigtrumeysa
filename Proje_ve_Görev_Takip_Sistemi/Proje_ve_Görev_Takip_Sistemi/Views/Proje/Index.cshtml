@model IEnumerable<Proje_ve_Görev_Takip_Sistemi.Models.Proje>

@{
    ViewData["Title"] = "Proje Listesi";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary"><i class="bi bi-list-task"></i> Aktif Projeler</h2>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-circle"></i> Yeni Proje Ekle
        </a>
    </div>

    <div class="card shadow">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Proje Adı</th>
                        <th>Açıklama</th>
                        <th>Oluşturulma Tarihi</th>
                        <th class="text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">@item.Ad</td>
                            <td>@item.Aciklama</td>
                            <td>@item.OlusturulmaTarihi.ToShortDateString()</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-info me-1">Detay</button>
                                <button class="btn btn-sm btn-outline-danger">Sil</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>