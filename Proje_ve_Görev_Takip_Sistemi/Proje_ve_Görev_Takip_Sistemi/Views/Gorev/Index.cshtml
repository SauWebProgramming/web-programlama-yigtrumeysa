@model IEnumerable<Proje_ve_Görev_Takip_Sistemi.Models.Gorev>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark"><i class="bi bi-list-check"></i> Tüm Görevler</h2>
        <a asp-action="Create" class="btn btn-primary">Yeni Görev Ekle</a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-start border-4 border-primary">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">@item.Ad</h5>
                        <h6 class="card-subtitle mb-2 text-muted">
                            <i class="bi bi-folder2-open"></i> @(item.Proje?.Ad ?? "Proje Atanmamış")
                        </h6>
                        <p class="card-text text-secondary">@item.Aciklama</p>
                    </div>
                    <div class="card-footer bg-transparent border-0 text-end">
                        <small class="text-muted">@item.OlusturulmaTarihi.ToShortDateString()</small>
                    </div>
                </div>
            </div>
        }
    </div>
</div>