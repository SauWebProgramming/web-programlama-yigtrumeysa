@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="container mt-5">
    <div class="row justify-content-center text-center mb-5">
        <div class="col-md-8">
            <h1 class="display-4 fw-bold mb-2" style="color: #4A3B32;">Proje ve Görevlerini Kolayca Takip Et</h1>
            <p class="fs-5" style="color: #7A6556; font-weight: 300;">Haydi Başlayalım.</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-5 mb-4">
            <div class="card card-gradient-pink h-100 text-center py-5 shadow-sm">
                <div class="card-body">
                    <i class="bi bi-folder2-open display-3 mb-3" style="color: #4A3B32;"></i>
                    <h2 class="fw-bold" style="color: #4A3B32;">@ViewBag.ProjeSayisi</h2>
                    <p class="fw-medium fs-5" style="color: #4A3B32;">Aktif Proje</p>
                    <a asp-controller="Proje" asp-action="Index" class="btn btn-outline-dark mt-3 px-4 rounded-pill">İncele</a>
                </div>
            </div>
        </div>

        <div class="col-md-5 mb-4">
            <div class="card card-gradient-pink h-100 text-center py-5 shadow-sm">
                <div class="card-body">
                    <i class="bi bi-list-check display-3 mb-3" style="color: #4A3B32;"></i>
                    <h2 class="fw-bold" style="color: #4A3B32;">@ViewBag.GorevSayisi</h2>
                    <p class="fw-medium fs-5" style="color: #4A3B32;">Aktif Görev</p>
                    <a asp-controller="Gorev" asp-action="Index" class="btn btn-outline-dark mt-3 px-4 rounded-pill">İncele</a>
                </div>
            </div>
        </div>
    </div>
</div>